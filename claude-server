#!/usr/bin/env bash
# claude-server — portable start/stop wrapper

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
PID_FILE="$SCRIPT_DIR/.claude-server.pid"
LOG_FILE="$SCRIPT_DIR/claude-server.log"
CMD="python3 $SCRIPT_DIR/claude-server.py --skip-permissions"

_pid() { [[ -f "$PID_FILE" ]] && cat "$PID_FILE"; }

_running() {
    local pid; pid=$(_pid)
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

start() {
    if _running; then
        echo "already running (pid $(_pid))"
        return
    fi
    nohup $CMD >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    echo "started (pid $!)"
}

stop() {
    if ! _running; then
        echo "not running"
        rm -f "$PID_FILE"
        return
    fi
    kill "$(_pid)" && rm -f "$PID_FILE"
    echo "stopped"
}

status() {
    if _running; then
        local pid; pid=$(_pid)
        local uptime; uptime=$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ')
        local port; port=$(ss -tlnp 2>/dev/null | grep "pid=$pid," | grep -oP ':\K[0-9]+' | head -1)
        local mem; mem=$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.1f MB", $1/1024}')
        echo "status:  running"
        echo "pid:     $pid"
        echo "uptime:  ${uptime:-unknown}"
        echo "port:    ${port:-unknown}"
        echo "memory:  ${mem:-unknown}"
        echo "log:     $LOG_FILE"
    else
        echo "status:  stopped"
        rm -f "$PID_FILE"
    fi
}

uninstall() {
    stop 2>/dev/null
    rm -f "$HOME/.local/bin/claude-server"
    sed -i '/export PATH="\$HOME\/.local\/bin:\$PATH"/d' "$HOME/.bashrc"
    echo "uninstalled"
}

case "${1:-status}" in
    start)     start     ;;
    stop)      stop      ;;
    restart)   stop; sleep 1; start ;;
    status)    status    ;;
    log)       tail -f "$LOG_FILE" ;;
    uninstall) uninstall ;;
    *)         echo "usage: claude-server {start|stop|restart|status|log|uninstall}" ;;
esac
